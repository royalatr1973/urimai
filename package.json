{
  "name": "urimai",
  "version": "0.0.0",
  "private": true,
  "description": "Urimai — helps Indian citizens discover and claim the welfare schemes they're entitled to.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @urimai/db generate",
    "db:migrate": "pnpm --filter @urimai/db migrate",
    "db:reset": "pnpm --filter @urimai/db reset",
    "db:studio": "pnpm --filter @urimai/db studio",
    "seed": "pnpm --filter @urimai/db seed",
    "schemes:list": "pnpm --filter @urimai/db schemes:list",
    "extract:smoke": "pnpm --filter @urimai/extractor extract:smoke",
    "sim": "pnpm --filter @urimai/orchestrator sim",
    "api:dev": "pnpm --filter @urimai/api dev",
    "web:dev": "pnpm --filter @urimai/web dev",
    "web:build": "pnpm --filter @urimai/web build",
    "wa:dev": "pnpm --filter @urimai/whatsapp dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
