{
  "name": "@urimai/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts",
    "start": "dotenv -e ../../.env -- node dist/server.js"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.1.1",
    "@urimai/cache": "workspace:*",
    "@urimai/db": "workspace:*",
    "@urimai/extractor": "workspace:*",
    "@urimai/orchestrator": "workspace:*",
    "@urimai/types": "workspace:*",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "dotenv-cli": "^7.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
