# =============================================================================
# Urimai — environment template. Copy to `.env` and fill in. NEVER commit `.env`.
# The browser must never receive any of these values. Server-side only.
# =============================================================================

# ----- Core data store: PostgreSQL (versioned schemes & rules) ----------------
# Use an India region in production (data residency for welfare data).
DATABASE_URL="postgresql://urimai:urimai@localhost:5432/urimai?schema=public"

# ----- Session cache: Redis ---------------------------------------------------
REDIS_URL="redis://localhost:6379"

# ----- LLM profile extractor: Anthropic (Claude) — Phase 2 --------------------
# Server-side ONLY. The LLM understands; it never decides eligibility.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# ----- Tamil ASR / TTS — Phase 5 ----------------------------------------------
# Bhashini primary, Sarvam AI commercial fallback (behind one SpeechProvider).
SPEECH_PROVIDER="bhashini"           # "bhashini" | "sarvam"
BHASHINI_API_KEY=""
BHASHINI_USER_ID=""
BHASHINI_PIPELINE_ID=""
SARVAM_API_KEY=""

# ----- WhatsApp Cloud API — Phase 5 -------------------------------------------
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""             # for webhook verification handshake
WHATSAPP_APP_SECRET=""               # to validate inbound webhook signatures

# ----- Object storage / CDN for document image assets — Phase 5 ---------------
ASSETS_BUCKET=""
ASSETS_CDN_BASE_URL=""

# ----- Beneficiary PII encryption — Phase 6 -----------------------------------
# Identity/PII appears ONLY at the apply step, stored encrypted at rest.
# Ciphertexts are key-versioned ("<keyId>:iv:tag:data") so keys can rotate without
# data loss: point PII_ENCRYPTION_KEY at the new key, bump PII_ACTIVE_KEY_ID, and
# keep the old key in PII_RETIRED_KEYS ("id=base64,id=base64").
PII_ENCRYPTION_KEY=""                # 32-byte key, base64-encoded (AES-256-GCM)
PII_ACTIVE_KEY_ID="k1"
PII_RETIRED_KEYS=""

# ----- Operator access ---------------------------------------------------------
# Bearer token for /api/operator/* (these routes decrypt PII). Unset = routes 503.
OPERATOR_TOKEN=""

# ----- API gateway ------------------------------------------------------------
API_PORT="3000"
API_HOST="0.0.0.0"
NODE_ENV="development"
